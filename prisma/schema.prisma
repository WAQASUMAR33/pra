datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model MerchantConfig {
  id            Int      @id @default(autoincrement())
  posId         String   @db.VarChar(50)
  token         String   @db.VarChar(255)
  branchName    String   @db.VarChar(100)
  branchAddress String   @db.VarChar(255)
  apiUrl        String   @db.VarChar(255) @default("https://ims.pral.com.pk/ims/sandbox/api/Live/PostData")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @db.VarChar(50)
  posId           String        @db.VarChar(50)
  usin            String        @unique @db.VarChar(100)
  dateTime        DateTime      @default(now())
  buyerNtn        String?       @db.VarChar(20)
  buyerCnic       String?       @db.VarChar(20)
  buyerName       String?       @db.VarChar(100)
  buyerPhone      String?       @db.VarChar(20)
  invoiceType     Int           @default(1) // 1 = Sale, 2 = Sale Return/Credit Note, 3 = Debit Note
  totalQuantity   Int
  totalSaleValue  Decimal       @db.Decimal(12, 2)
  totalTaxCharged Decimal       @db.Decimal(12, 2)
  totalDiscount   Decimal       @db.Decimal(12, 2) @default(0.00)
  totalBillAmount Decimal       @db.Decimal(12, 2)
  paymentMode     Int           @default(1) // 1 = Cash, 2 = Card, 3 = Mobile Wallet, 4 = Other
  status          String        @db.VarChar(20) @default("DRAFT") // DRAFT, PENDING, SUCCESS, FAILED
  praFiscalNumber String?       @db.VarChar(100) // Returned from PRA API
  praResponseCode String?       @db.VarChar(10)
  praResponseMsg  String?       @db.Text
  eventType       String?       @db.VarChar(50)
  eventDate       DateTime?
  numberOfGuests   Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           InvoiceItem[]
}

model InvoiceItem {
  id                 String   @id @default(uuid())
  invoiceId          String
  invoice            Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemCode           String   @db.VarChar(50)
  itemName           String   @db.VarChar(150)
  quantity           Int
  pctCode            String?  @db.VarChar(20) // Tariffs classification
  taxRate            Decimal  @db.Decimal(5, 2) // e.g. 16.00, 5.00
  saleValue          Decimal  @db.Decimal(12, 2) // Qty * Price before tax
  salesTaxApplicable Decimal  @db.Decimal(12, 2) // Tax amount
  furtherTax         Decimal  @db.Decimal(12, 2) @default(0.00)
  federalTax         Decimal  @db.Decimal(12, 2) @default(0.00)
  discount           Decimal  @db.Decimal(12, 2) @default(0.00)
  netAmount          Decimal  @db.Decimal(12, 2) // net amount for item
}
